# ============================================================
# JARVIS BOT — 環境変数テンプレート
# このファイルを .env.local にコピーして使う
# cp .env.local.example .env.local
# ============================================================

# ============================================================
# Phase 1 (現在必須)
# ============================================================

# Claude API キー
# 取得先: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxx

# ============================================================
# Phase 2 (Supabase + 認証 — 未設定でも動く)
# ============================================================

# Supabase
# 取得先: https://supabase.com/ → プロジェクト設定 → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxxxxxxxxxxxxxxxxx
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxxxxxxxxxxxxxxx

# NextAuth.js 認証
# NEXTAUTH_SECRET は openssl rand -base64 32 で生成
NEXTAUTH_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NEXTAUTH_URL=http://localhost:3000

# Google OAuth（Googleログイン用）
# 取得先: https://console.cloud.google.com/ → 認証情報
GOOGLE_CLIENT_ID=xxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxx

# ============================================================
# Phase 3 (外部連携 — 未設定でも動く)
# ============================================================

# Nango（外部サービス連携 OAuth管理）
# 取得先: https://app.nango.dev/ → Project Settings → Secret Key
NANGO_SECRET_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_NANGO_PUBLIC_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Slack Bot
SLACK_BOT_TOKEN=xoxb-xxxxxxxx
SLACK_SIGNING_SECRET=xxxxxxxx

# X (Twitter) API
X_API_KEY=xxxxxxxx
X_API_SECRET=xxxxxxxx
X_ACCESS_TOKEN=xxxxxxxx
X_ACCESS_SECRET=xxxxxxxx

# ============================================================
# アプリ設定
# ============================================================

# 本番URL (Vercelの場合は自動設定される)
NEXT_PUBLIC_APP_URL=http://localhost:3000
